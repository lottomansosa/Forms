<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Our Current Users</h1>
    <ul>
    <% 
        let counter = 0;
        //let users = locals.users;
        for (user of users){ %>
            <li><a href="/users/<%=counter%>"><%= user.firstName %> <%= user.lastName %></a> </li>
            <%counter++%>

        <% } %>
        </ul>
</body>
</html>